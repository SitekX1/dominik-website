# Kopiere diese Datei zu .env.local und trage die echten Werte ein
# .env.local wird NICHT committed

# Beispiel: E-Mail (Resend)
# RESEND_API_KEY=re_xxxxx

# Beispiel: Datenbank
# DATABASE_URL=postgresql://...

# Beispiel: Öffentliche Vars (im Browser verfügbar)
# NEXT_PUBLIC_SITE_URL=https://dominik-website.de
